{
  "name": "aas-companion",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "dev": "pnpm --filter @aas-companion/web dev",
    "build": "pnpm --filter @aas-companion/web build",
    "lint": "pnpm --filter \"@aas-companion/*\" -r --if-present lint",
    "typecheck": "pnpm --filter \"@aas-companion/*\" -r --if-present typecheck",
    "test": "pnpm --filter @aas-companion/web test",
    "test:e2e": "pnpm --filter @aas-companion/web test:e2e",
    "db:generate": "node --env-file=.env.local ./packages/db/node_modules/prisma/build/index.js generate --schema packages/db/prisma/schema.prisma",
    "db:push": "node --env-file=.env.local ./packages/db/node_modules/prisma/build/index.js db push --schema packages/db/prisma/schema.prisma",
    "db:seed": "node --env-file=.env.local packages/db/prisma/seed.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@next/eslint-plugin-next": "^15.2.2",
    "@playwright/test": "^1.51.1",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "protobufjs",
      "core-js"
    ]
  }
}
