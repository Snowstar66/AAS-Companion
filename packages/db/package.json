{
  "name": "@aas-companion/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./organization-repository": {
      "types": "./dist/repositories/organization-repository.d.ts",
      "default": "./dist/repositories/organization-repository.js"
    }
  },
  "scripts": {
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@aas-companion/domain": "workspace:*",
    "@prisma/client": "^6.4.1",
    "prisma": "^6.4.1"
  }
}
