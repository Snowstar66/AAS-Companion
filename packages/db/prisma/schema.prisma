generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  value_owner
  aida
  aqa
  architect
  delivery_lead
  builder
}

enum OrganizationSide {
  customer
  supplier
}

enum PartyRoleType {
  customer_sponsor
  customer_domain_owner
  value_owner
  architect
  aida
  aqa
  delivery_lead
  builder
  ai_governance_lead
  risk_owner
}

enum AgentType {
  bmad_agent
  governance_agent
  automation_agent
}

enum OutcomeStatus {
  draft
  baseline_in_progress
  ready_for_tg1
  active
}

enum EpicStatus {
  draft
  in_progress
  completed
}

enum StoryType {
  outcome_delivery
  governance
  enablement
}

enum StoryStatus {
  draft
  definition_blocked
  ready_for_handoff
  in_progress
}

enum GovernedObjectOriginType {
  seeded
  native
  imported
}

enum GovernedObjectCreatedMode {
  demo
  clean
  promotion
}

enum GovernedLifecycleState {
  active
  archived
}

enum LineageSourceType {
  artifact_intake_session
  artifact_intake_file
  artifact_aas_candidate
}

enum ArtifactAasCandidateType {
  outcome
  epic
  story
}

enum ArtifactAasMappingState {
  mapped
  uncertain
  missing
}

enum ArtifactComplianceFindingCategory {
  missing
  uncertain
  human_only
  blocked
}

enum ArtifactCandidateReviewStatus {
  pending
  confirmed
  edited
  rejected
  follow_up_needed
  promoted
}

enum ImportedGovernedReadinessState {
  imported
  imported_incomplete
  imported_human_review_needed
  imported_framing_ready
  imported_design_ready
  blocked
}

enum TollgateEntityType {
  outcome
  story
}

enum TollgateType {
  tg1_baseline
  story_readiness
}

enum TollgateStatus {
  blocked
  ready
  approved
}

enum SignoffDecisionKind {
  review
  approval
  escalation
}

enum SignoffDecisionStatus {
  approved
  rejected
  changes_requested
}

enum ActivityEntityType {
  organization
  outcome
  epic
  story
  tollgate
  signoff_record
  party_role_entry
  agent_registry_entry
  artifact_intake_session
  artifact_intake_file
  artifact_aas_candidate
}

enum ActivityEventType {
  demo_seeded
  outcome_created
  outcome_updated
  epic_created
  epic_updated
  story_created
  story_updated
  tollgate_recorded
  signoff_recorded
  execution_contract_generated
  governed_removal_requested
  governed_hard_deleted
  governed_archived
  governed_restored
  party_role_entry_created
  party_role_entry_updated
  party_role_entry_deactivated
  agent_registry_entry_created
  agent_registry_entry_updated
  agent_registry_entry_deactivated
  artifact_intake_session_created
  artifact_file_uploaded
  artifact_file_rejected
  artifact_candidate_compliance_analyzed
  artifact_candidate_confirmed
  artifact_candidate_edited
  artifact_candidate_rejected
  artifact_candidate_follow_up_marked
  artifact_candidate_promoted
  imported_progression_blocked
  imported_progression_allowed
}

enum ArtifactIntakeSessionStatus {
  uploaded
  source_classification_pending
  source_classified
  parsing_pending
  parsed
  mapping_pending
  human_review_required
  promoted
  blocked
}

enum ArtifactSourceTypeStatus {
  pending
  classified
}

enum ArtifactSourceType {
  bmad_prd
  epic_file
  story_file
  mixed_markdown_bundle
  unknown_artifact
}

enum ExtractionConfidence {
  high
  medium
  low
}

enum RiskProfile {
  low
  medium
  high
}

enum AiAccelerationLevel {
  level_1
  level_2
  level_3
}

model Organization {
  id                           String                        @id
  slug                         String                        @unique
  name                         String
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  memberships                  Membership[]
  outcomes                     Outcome[]
  epics                        Epic[]
  stories                      Story[]
  tollgates                    Tollgate[]
  signoffRecords               SignoffRecord[]
  activityEvents               ActivityEvent[]
  artifactIntakeSessions       ArtifactIntakeSession[]
  artifactIntakeFiles          ArtifactIntakeFile[]
  artifactAasCandidates        ArtifactAasCandidate[]
  partyRoleEntries             PartyRoleEntry[]
  agentRegistryEntries         AgentRegistryEntry[]
  governanceRoleRequirements   GovernanceRoleRequirement[]
  governanceRiskCombinationRules GovernanceRiskCombinationRule[]
}

model AppUser {
  id                   String                @id
  email                String                @unique
  fullName             String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  memberships          Membership[]
  ownedOutcomes        Outcome[]             @relation("OutcomeValueOwner")
  tollgateDecisions    Tollgate[]            @relation("TollgateDecisionActor")
  createdSignoffRecords SignoffRecord[]      @relation("SignoffCreator")
  activityEvents       ActivityEvent[]       @relation("ActivityActor")
  createdIntakeSessions ArtifactIntakeSession[] @relation("ArtifactIntakeSessionCreator")
  uploadedIntakeFiles  ArtifactIntakeFile[]  @relation("ArtifactIntakeFileUploader")
}

model Membership {
  id             String         @id
  organizationId String
  userId         String
  role           MembershipRole
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model PartyRoleEntry {
  id               String           @id
  organizationId   String
  fullName         String
  email            String
  phoneNumber      String?
  avatarUrl        String?
  organizationSide OrganizationSide
  roleType         PartyRoleType
  roleTitle        String
  mandateNotes     String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supervisingAgents AgentRegistryEntry[] @relation("PartyRoleSupervisor")
  signoffRecords   SignoffRecord[]  @relation("ActualSignoffPerson")

  @@index([organizationId, isActive, organizationSide])
  @@index([organizationId, roleType, isActive])
}

model AgentRegistryEntry {
  id                     String         @id
  organizationId         String
  agentName              String
  agentType              AgentType
  purpose                String
  scopeOfWork            String
  allowedArtifactTypes   String[]       @default([])
  allowedActions         String[]       @default([])
  supervisingPartyRoleId String
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  organization           Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supervisingPartyRole   PartyRoleEntry @relation("PartyRoleSupervisor", fields: [supervisingPartyRoleId], references: [id], onDelete: Restrict)

  @@index([organizationId, isActive, agentType])
  @@index([organizationId, supervisingPartyRoleId])
}

model GovernanceRoleRequirement {
  id               String           @id
  organizationId   String
  aiAccelerationLevel AiAccelerationLevel
  organizationSide OrganizationSide
  roleType         PartyRoleType
  minimumCount     Int
  rationale        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, aiAccelerationLevel, organizationSide, roleType])
  @@index([organizationId, aiAccelerationLevel])
}

model GovernanceRiskCombinationRule {
  id                 String              @id
  organizationId     String
  aiAccelerationLevel AiAccelerationLevel
  primaryRoleType    PartyRoleType
  conflictingRoleType PartyRoleType
  rationale          String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, aiAccelerationLevel, primaryRoleType, conflictingRoleType])
  @@index([organizationId, aiAccelerationLevel])
}

model Outcome {
  id                  String              @id
  organizationId      String
  key                 String
  title               String
  problemStatement    String?
  outcomeStatement    String?
  baselineDefinition  String?
  baselineSource      String?
  timeframe           String?
  valueOwnerId        String?
  riskProfile         RiskProfile         @default(medium)
  aiAccelerationLevel AiAccelerationLevel @default(level_2)
  status              OutcomeStatus       @default(draft)
  originType          GovernedObjectOriginType @default(native)
  createdMode         GovernedObjectCreatedMode @default(clean)
  lifecycleState      GovernedLifecycleState @default(active)
  archivedAt          DateTime?
  archiveReason       String?
  lineageSourceType   LineageSourceType?
  lineageSourceId     String?
  lineageNote         String?
  importedReadinessState ImportedGovernedReadinessState?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  valueOwner          AppUser?            @relation("OutcomeValueOwner", fields: [valueOwnerId], references: [id], onDelete: SetNull)
  epics               Epic[]
  stories             Story[]

  @@unique([organizationId, key])
  @@index([organizationId, originType])
  @@index([organizationId, lifecycleState])
}

model Epic {
  id             String       @id
  organizationId String
  outcomeId      String
  key            String
  title          String
  purpose        String
  summary        String?
  status         EpicStatus   @default(draft)
  originType     GovernedObjectOriginType @default(native)
  createdMode    GovernedObjectCreatedMode @default(clean)
  lifecycleState GovernedLifecycleState @default(active)
  archivedAt     DateTime?
  archiveReason  String?
  lineageSourceType LineageSourceType?
  lineageSourceId   String?
  lineageNote       String?
  importedReadinessState ImportedGovernedReadinessState?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  outcome        Outcome      @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  stories        Story[]

  @@unique([organizationId, key])
  @@index([organizationId, originType])
  @@index([organizationId, lifecycleState])
}

model Story {
  id                  String              @id
  organizationId      String
  outcomeId           String
  epicId              String
  key                 String
  title               String
  storyType           StoryType
  valueIntent         String
  acceptanceCriteria  String[]            @default([])
  aiUsageScope        String[]            @default([])
  aiAccelerationLevel AiAccelerationLevel @default(level_2)
  testDefinition      String?
  definitionOfDone    String[]            @default([])
  status              StoryStatus         @default(draft)
  originType          GovernedObjectOriginType @default(native)
  createdMode         GovernedObjectCreatedMode @default(clean)
  lifecycleState      GovernedLifecycleState @default(active)
  archivedAt          DateTime?
  archiveReason       String?
  lineageSourceType   LineageSourceType?
  lineageSourceId     String?
  lineageNote         String?
  importedReadinessState ImportedGovernedReadinessState?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  outcome             Outcome             @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  epic                Epic                @relation(fields: [epicId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId, originType])
  @@index([organizationId, lifecycleState])
}

model Tollgate {
  id             String             @id
  organizationId String
  entityType     TollgateEntityType
  entityId       String
  tollgateType   TollgateType
  status         TollgateStatus     @default(blocked)
  blockers       String[]           @default([])
  approverRoles  MembershipRole[]   @default([])
  decidedBy      String?
  decidedAt      DateTime?
  comments       String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  decisionActor  AppUser?           @relation("TollgateDecisionActor", fields: [decidedBy], references: [id], onDelete: SetNull)
  signoffRecords SignoffRecord[]

  @@unique([organizationId, entityType, entityId, tollgateType])
  @@index([organizationId, entityType, entityId])
}

model SignoffRecord {
  id                   String               @id
  organizationId       String
  entityType           TollgateEntityType
  entityId             String
  tollgateId           String?
  tollgateType         TollgateType?
  decisionKind         SignoffDecisionKind
  requiredRoleType     PartyRoleType
  actualPartyRoleEntryId String
  actualPersonName     String
  actualPersonEmail    String
  actualRoleTitle      String
  organizationSide     OrganizationSide
  decisionStatus       SignoffDecisionStatus
  note                 String?
  evidenceReference    String?
  createdBy            String?
  createdAt            DateTime             @default(now())
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tollgate             Tollgate?            @relation(fields: [tollgateId], references: [id], onDelete: SetNull)
  actualPartyRoleEntry PartyRoleEntry       @relation("ActualSignoffPerson", fields: [actualPartyRoleEntryId], references: [id], onDelete: Restrict)
  creator              AppUser?             @relation("SignoffCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType, entityId, createdAt])
  @@index([organizationId, tollgateId, createdAt])
  @@index([organizationId, decisionKind, decisionStatus])
}

model ActivityEvent {
  id             String             @id
  organizationId String
  entityType     ActivityEntityType
  entityId       String
  eventType      ActivityEventType
  actorId        String?
  metadata       Json?
  createdAt      DateTime           @default(now())
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          AppUser?           @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, createdAt])
}

model ArtifactIntakeSession {
  id             String                    @id
  organizationId String
  label          String
  status         ArtifactIntakeSessionStatus @default(uploaded)
  mappedArtifacts Json?
  mappingCompletedAt DateTime?
  createdBy      String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        AppUser?                  @relation("ArtifactIntakeSessionCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  files          ArtifactIntakeFile[]
  candidates     ArtifactAasCandidate[]

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
}

model ArtifactIntakeFile {
  id               String                   @id
  intakeSessionId  String
  organizationId   String
  fileName         String
  mimeType         String?
  extension        String
  sizeBytes        Int
  content          String
  sourceTypeStatus ArtifactSourceTypeStatus @default(pending)
  sourceType       ArtifactSourceType?
  sourceTypeConfidence ExtractionConfidence?
  classifiedAt     DateTime?
  parsedAt         DateTime?
  parsedArtifacts  Json?
  uploadedBy       String?
  uploadedAt       DateTime                 @default(now())
  intakeSession    ArtifactIntakeSession    @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploader         AppUser?                 @relation("ArtifactIntakeFileUploader", fields: [uploadedBy], references: [id], onDelete: SetNull)
  candidates       ArtifactAasCandidate[]

  @@index([organizationId, uploadedAt])
  @@index([organizationId, sourceTypeStatus])
  @@index([intakeSessionId])
}

model ArtifactAasCandidate {
  id                        String                        @id
  intakeSessionId           String
  fileId                    String
  organizationId            String
  type                      ArtifactAasCandidateType
  title                     String
  summary                   String
  mappingState              ArtifactAasMappingState
  sourceType                ArtifactSourceType
  sourceConfidence          ExtractionConfidence
  sourceSectionId           String
  sourceSectionTitle        String
  sourceSectionMarker       String
  inferredOutcomeCandidateId String?
  inferredEpicCandidateId   String?
  relationshipState         ArtifactAasMappingState
  relationshipNote          String?
  acceptanceCriteria        String[]                      @default([])
  testNotes                 String[]                      @default([])
  draftRecord               Json
  humanDecisions            Json
  complianceResult          Json
  reviewStatus              ArtifactCandidateReviewStatus @default(pending)
  reviewComment             String?
  followUpNeeded            Boolean                       @default(false)
  importedReadinessState    ImportedGovernedReadinessState?
  promotedEntityType        ArtifactAasCandidateType?
  promotedEntityId          String?
  promotedAt                DateTime?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  organization              Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  intakeSession             ArtifactIntakeSession         @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)
  file                      ArtifactIntakeFile            @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([organizationId, intakeSessionId])
  @@index([organizationId, fileId])
  @@index([organizationId, reviewStatus])
}
