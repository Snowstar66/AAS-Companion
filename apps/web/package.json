{
  "name": "@aas-companion/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node ../../scripts/sync-prisma-client.mjs",
    "dev": "node --env-file=../../.env.local ./node_modules/next/dist/bin/next dev",
    "prebuild": "node ../../scripts/sync-prisma-client.mjs",
    "build": "node -e \"const fs=require('fs'); fs.rmSync('.next',{ recursive:true, force:true });\" && node --env-file=../../.env.local ./node_modules/next/dist/bin/next build",
    "prestart": "node ../../scripts/sync-prisma-client.mjs",
    "start": "node --env-file=../../.env.local ./node_modules/next/dist/bin/next start",
    "lint": "eslint .",
    "typecheck": "node -e \"const fs=require('fs'); fs.rmSync('.next',{ recursive:true, force:true }); fs.rmSync('tsconfig.tsbuildinfo',{ force:true });\" && tsc --project tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:e2e": "playwright test --config playwright.config.ts --pass-with-no-tests"
  },
  "dependencies": {
    "@aas-companion/api": "workspace:*",
    "@aas-companion/config": "workspace:*",
    "@aas-companion/db": "workspace:*",
    "@aas-companion/domain": "workspace:*",
    "@aas-companion/ui": "workspace:*",
    "@hookform/resolvers": "^4.1.3",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "next": "^15.2.2",
    "posthog-js": "^1.226.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.15",
    "tailwindcss": "^4.0.15"
  }
}
